# By default everything in .env is a string even if "" are not metioned

# App
VITE_APP_NAME=UserManagementSystem
VITE_APP_VERSION=1.0.0

# Auth config
VITE_OTP_LENGTH=6
VITE_OTP_EXPIRY_SECONDS=1800
VITE_MAX_LOGIN_ATTEMPTS=5

# Request config
VITE_REQUEST_TIMEOUT_MS=10000

# Token config
VITE_ACCESS_TOKEN_EXPIRY_MINUTES=15

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
